#!/bin/bash

OPTION=$(printf "Power Off\nReboot\nLogout\nLock" | wofi --dmenu --prompt "System Menu:")

# TODO: use hyprshutdown whenether is possible to install (AUR or pacman)
case "$OPTION" in
"Power Off") hyprshutdown -t 'Shutting down...' --post-cmd 'shutdown -P 0' ;;
"Reboot") hyprshutdown -t 'Restarting...' --post-cmd 'reboot' ;;
"Logout") hyprshutdown ;;
"Lock") hyprlock ;;
esac
